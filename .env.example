# Frontend URL (used for sitemaps, email links, SEO)
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_DOMAIN="localhost:3000"
NEXT_PUBLIC_SCHEME="http://"

# Backend API URL (used for Next.js fallback rewrites)
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"

# Resend (Email)
# Get API key from https://resend.com
RESEND_API_KEY="your_resend_api_key_here"

# UploadThing (File Uploads)
# Get from https://uploadthing.com
UPLOADTHING_TOKEN="your_uploadthing_token_here"

# Support email (displayed in contact/help sections)
NEXT_PUBLIC_SUPPORT_EMAIL="support@loftcommunity.com"

# UploadCare (File upload widget in settings)
NEXT_PUBLIC_UPLOADCARE_PUBKEY="your_uploadcare_pubkey_here"
