# =============================================================================
# Loft Frontend — Environment Variables
# =============================================================================
# Copy this file to .env (or .env.local) and fill in your values.
# NEXT_PUBLIC_* vars are inlined at build time and visible in the browser.
#
# Required vars that MUST be set in Vercel dashboard:
#   NEXT_PUBLIC_BACKEND_URL, NEXT_PUBLIC_URL, RESEND_API_KEY, UPLOADTHING_TOKEN

# --- Backend API ---
# Where the Next.js fallback rewrites proxy /api/* requests
# In dev: http://localhost:4000
# In prod: https://your-backend.onrender.com
NEXT_PUBLIC_BACKEND_URL="http://localhost:4000"

# --- Canonical URL (SEO, email links, sitemap) ---
NEXT_PUBLIC_URL="http://localhost:3000"

# --- Email (Resend) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY="re_..."

# --- File Uploads (UploadThing) ---
# Get from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="your_uploadthing_token_here"

# --- Contact/Support ---
# Displayed throughout the UI for users to reach support
NEXT_PUBLIC_SUPPORT_EMAIL="support@loftcommunity.com"

# --- UploadCare (profile picture upload in settings) ---
# Get from https://uploadcare.com/dashboard
NEXT_PUBLIC_UPLOADCARE_PUBKEY="your_uploadcare_pubkey_here"
